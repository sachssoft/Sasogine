	  <Compile Include="..\..\Colors\Core\ColorTransformers.cs" Link="Graphics\Colors\ColorTransformers.cs" />
	  <Compile Include="..\..\Colors\Core\ColorUtils.cs" Link="Graphics\Colors\ColorUtils.cs" />
	  <Compile Include="..\..\Colors\Core\IColorAdjustment.cs" Link="Graphics\Colors\IColorAdjustment.cs" />
