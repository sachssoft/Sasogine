	  <Compile Include="..\..\Colors\Core\IColorTransformer.cs" Link="Graphics\Colors\IColorTransformer.cs" />
	  <Compile Include="..\..\Colors\Core\List\BasicColors.cs" Link="Graphics\Colors\List\BasicColors.cs" />
	  <Compile Include="..\..\Colors\Core\List\KnownColors.cs" Link="Graphics\Colors\List\KnownColors.cs" />
	  <Compile Include="..\..\Colors\Core\List\RALColors.cs" Link="Graphics\Colors\List\RALColors.cs" />
