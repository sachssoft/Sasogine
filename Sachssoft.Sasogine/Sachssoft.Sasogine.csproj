	  <Compile Include="..\..\Colors\Core\ColorName.cs" Link="Graphics\Colors\ColorName.cs" />
	  <Compile Include="..\..\Colors\Core\ColorRange.cs" Link="Graphics\Colors\ColorRange.cs" />
	  <Compile Include="..\..\Colors\Core\ColorSpaces.cs" Link="Graphics\Colors\ColorSpaces.cs" />
