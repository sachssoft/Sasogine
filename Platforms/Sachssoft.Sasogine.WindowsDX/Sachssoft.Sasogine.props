<Project>
	<PropertyGroup>
		<RootNamespace>Sachssoft.Sasogine</RootNamespace>
		<Nullable>enable</Nullable>
		<AllowUnsafeBlocks>True</AllowUnsafeBlocks>
		<Title>Sasogine</Title>
		<Copyright>© Tobias Sachs (Sachssoft)</Copyright>
	</PropertyGroup>

	<PropertyGroup>
		<IsTrimmable>True</IsTrimmable>
		<IsAotCompatible>True</IsAotCompatible>
	</PropertyGroup>
	
	<ItemGroup>
		<PackageReference Include="FontStashSharp.MonoGame" Version="1.5.6" />
		<PackageReference Include="LibTessDotNet" Version="1.1.15" />
		<PackageReference Include="NLayer" Version="1.16.0" />
		<PackageReference Include="NVorbis" Version="0.10.5" />
	</ItemGroup>
</Project>