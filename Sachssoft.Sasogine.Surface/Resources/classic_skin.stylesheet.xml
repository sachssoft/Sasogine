<?xml version="1.0" encoding="utf-8"?>
<Stylesheet>
	<Atlas File="classic_skin_96dpi.atlas.xml" Name="classic_skin_96dpi" Scale="1" Dpi="96" />
	<!--<Atlas File="default_ui_skin.xmat" Scale="2" Dpi="192" />-->

	<Typeface Name="Noto">
		<Variant File="NotoSans-Regular.ttf" Weight="Normal" Style="Normal" />
		<Variant File="NotoSans-Italic.ttf" Weight="Normal" Style="Italic" />
		<Variant File="NotoSans-Bold.ttf" Weight="Bold" Style="Normal" />
		<Variant File="NotoSans-BoldItalic.ttf" Weight="Bold" Style="Italic" />
	</Typeface>

	<Typeface Name="Literata">
		<Variant File="Literata-Regular.ttf" Weight="Normal" Style="Normal" />
		<Variant File="Literata-Italic.ttf" Weight="Normal" Style="Italic" />
		<Variant File="Literata-Bold.ttf" Weight="Bold" Style="Normal" />
		<Variant File="Literata-BoldItalic.ttf" Weight="Bold" Style="Italic" />
	</Typeface>

	<Typeface Name="Cousine">
		<Variant File="Cousine-Regular.ttf" Weight="Normal" Style="Normal" />
		<Variant File="Cousine-Italic.ttf" Weight="Normal" Style="Italic" />
		<Variant File="Cousine-Bold.ttf" Weight="Bold" Style="Normal" />
		<Variant File="Cousine-BoldItalic.ttf" Weight="Bold" Style="Italic" />
	</Typeface>

	<Typeface Name="Mono">
		<Variant File="inter-regular.ttf" Weight="Normal" Style="Normal" />
	</Typeface>

	<Font Id="default-font" Typeface="Noto" Size="20" Weight="Regular" Style="Normal" Decoration="None" />
	<Font Id="header-font" Typeface="Noto" Size="20" Weight="Bold" Style="Normal" Decoration="None" />
	<Font Id="text-font" Typeface="Cousine" Size="18" Weight="Regular" Style="Normal" Decoration="None" />
	<Font Id="tooltip-font" Typeface="Literata" Size="16" Weight="Regular" Style="Normal" Decoration="None" />

	<Brush Type="SolidColorBrush" Id="background"  />

	<Define Id="field-height" Value="25" />
	<Define Id="button-height" Value="30" />

	<Style Type="Label">
		<Values Font="default-font"
				TextColor="white"
				DisabledTextColor="gray"
				ClipToBounds="True"
				TextHorizontalAlignment="Left"
				HorizontalAlignment="Left"/>
	</Style>

	<Style Type="Label" Id="ToolTip">
		<Values Background="default-pane" 
				Padding="5" 
				Font="tooltip-font" 
				TextColor="white" />
	</Style>

	<Style Type="TextBox">
		<Values Background="field-border-default"
				HoveredBackground="field-border-hovered"
				DisabledBackground="field-border-disabled"
				FocusedBackground="field-border-focused"
				TextColor="white"
				DisabledTextColor="gray"
				Font="text-font"
				Cursor="cursor"
				SelectionColor="blue"
				CaretColor="white"
				Height="25"/>
	</Style>

	<Style Type="ScrollViewer">
		<Values Background="content-border-default"
				HorizontalScrollBackground="scroll-horizontal"
				HorizontalScrollThumb="scroll-knob-horizontal"
				VerticalScrollBackground="scroll"
				VerticalScrollThumb="scroll-knob-vertical"
				Padding="1"/>
	</Style>

	<Style Type="ContentControl">
		<Style Type="Label" Id="content">
			<Values HorizontalAlignment="Center"
					VerticalAlignment="Center"
					TextHorizontalAlignment="Center"
					TextVerticalAlignment="Center"
					Font="default-font"
					TextColor="blue"
					DisabledTextColor="gray" />
		</Style>
	</Style>

	<Style Type="Button">
		<Values Background="button-border-default"
				HoveredBackground="button-border-hovered"
				DisabledBackground="button-border-disabled"
				FocusedBackground="button-border-focused"
				PressedBackground="button-border-pressed"
				Width="120"
				Height="30" />
		<Style Type="Label" Id="content">
			<Values HorizontalAlignment="Center"
					VerticalAlignment="Center"
					TextHorizontalAlignment="Center"
					TextVerticalAlignment="Center"
					Font="default-font"
					TextColor="red"
					DisabledTextColor="gray" />
		</Style>
	</Style>

	<Style Type="RepeatButton">
		<Values Width="120"
				Height="30"
				Interval="100"
				Delay="400" 
				Background="button-border-default"
				HoveredBackground="button-border-hovered"
				DisabledBackground="button-border-disabled"
				FocusedBackground="button-border-focused"
				PressedBackground="button-border-pressed"/>
		<Style Type="Label" Id="content">
			<Values HorizontalAlignment="Center"
					VerticalAlignment="Center"
					TextHorizontalAlignment="Center"
					TextVerticalAlignment="Center"
					Font="default-font"
					TextColor="red"
					DisabledTextColor="gray" />
		</Style>
	</Style>

	<Style Type="Switch">
		<Values Background="switch_default"
				HoveredBackground="switch_hovered"
				DisabledBackground="switch_disabled"
				AnimationDuration="100"
				Width="52"
				Height="25" />
		<Style Type="Image" Id="knob">
			<Values Visual="switch_knob_default"
					DisabledVisual="switch_knob_disabled"
					HoveredVisual="switch_knob_default"
					PressedVisual="switch_knob_default" />
		</Style>
	</Style>

	<Style Type="ToggleButton">
		<Values Width="120"
				Height="30"
				Background="button-border-default"
				HoveredBackground="button-border-hovered"
				DisabledBackground="button-border-disabled"
				FocusedBackground="button-border-focused"
				PressedBackground="button-border-pressed"/>
		<Style Type="Label" Id="content">
			<Values HorizontalAlignment="Center"
					VerticalAlignment="Center"
					TextHorizontalAlignment="Center"
					TextVerticalAlignment="Center"
					Font="default-font"
					TextColor="red"
					DisabledTextColor="gray" />
		</Style>
	</Style>

	<Style Type="ChoiceButton">
		<Values Width="120"
				Height="30"
				Background="button-border-default"
				HoveredBackground="button-border-hovered"
				DisabledBackground="button-border-disabled"
				FocusedBackground="button-border-focused"
				PressedBackground="button-border-pressed"/>
		<Style Type="Label" Id="content">
			<Values HorizontalAlignment="Center"
					VerticalAlignment="Center"
					TextHorizontalAlignment="Center"
					TextVerticalAlignment="Center"
					Font="default-font"
					TextColor="red"
					DisabledTextColor="gray" />
		</Style>
	</Style>

	<Style Type="DropDownButton">
		<Values Width="120"
				Height="30"
				Background="button-border-default"
				HoveredBackground="button-border-hovered"
				DisabledBackground="button-border-disabled"
				FocusedBackground="button-border-focused"
				PressedBackground="button-border-pressed"/>
		<Style Type="Label" Id="content">
			<Values HorizontalAlignment="Center"
					VerticalAlignment="Center"
					TextHorizontalAlignment="Center"
					TextVerticalAlignment="Center"
					Font="default-font"
					TextColor="red"
					DisabledTextColor="gray" />
		</Style>
	</Style>

	<Style Type="Foldout">
		<Values IconHeaderSpacing="5"
				Background="button"
				ContenHorizontalAlignment="Stretch"
				ContentVerticalAlignment="Stretch"/>
		<Style Type="CheckBox">
			<Values CheckedImage="arrow-up"
					UncheckedImage="arrow-down"
					HorizontalAlignment="Stretch"/>
		</Style>
		<Style Type="Label" Id="header">
			<Values Background="button"
					HorizontalAlignment="Stretch"
					Font="header-font"/>
		</Style>
	</Style>

	<Style Type="CheckBox">
		<Values CheckContentSpacing="5" />
		<Style Type="Label">
			<Values Font="default-font"
					TextColor="white" />
		</Style>
		<Style Type="Image" Id="checked">
			<Values Visual="checkbox_checked_default"
					HoveredVisual="checkbox_checked_hovered"
					PressedVisual="checkbox_checked_default"
					DisabledVisual="checkbox_checked_disabled" />
		</Style>
		<Style Type="Image" Id="unchecked">
			<Values Visual="checkbox_unchecked_default"
					HoveredVisual="checkbox_unchecked_hovered"
					PressedVisual="checkbox_unchecked_default"
					DisabledVisual="checkbox_unchecked_disabled" />
		</Style>
	</Style>

	<Style Type="RadioButton">
		<Values CheckContentSpacing="5" />
		<Style Type="Label">
			<Values Font="default-font"
					TextColor="white" />
		</Style>
		<Style Type="Image" Id="checked">
			<Values Visual="checkbox_checked_default"
					HoveredVisual="radiobutton_checked_hovered"
					PressedVisual="radiobutton_checked_default"
					DisabledVisual="radiobutton_checked_disabled" />
		</Style>
		<Style Type="Image" Id="unchecked">
			<Values Visual="radiobutton_unchecked_default"
					HoveredVisual="radiobutton_unchecked_hovered"
					PressedVisual="radiobutton_unchecked_default"
					DisabledVisual="radiobutton_unchecked_disabled" />
		</Style>
	</Style>

	<Style Type="NumberSpinner">
		<Values Background="field-border-default"
				HoveredBackground="field-border-hovered"
				DisabledBackground="field-border-disabled"
				FocusedBackground="field-border-focused"
				Width="100"
				Height="25"/>
		<Style Type="TextBox" Id="value">
			<Values TextColor="white"
					DisabledTextColor="gray"
					Font="default-font"
					Cursor="cursor"
					Selection="selection"
					TextVerticalAlignment="Center"
					TextHorizontalAlignment="Center" />
		</Style>
		<Style Type="RepeatButton" Id="decrement">
			<Values Width="25"
					Height="25"
					Background="button"
					HoveredBackground="button-over"
					PressedBackground="button-down" />
			<Style Type="Image" Id="indicator">
				<Values Visual="arrow-left" />
			</Style>
		</Style>
		<Style Type="RepeatButton" Id="increment">
			<Values Width="25"
					Height="25"
					Background="button"
					HoveredBackground="button-over"
					PressedBackground="button-down" />
			<Style Type="Image" Id="indicator">
				<Values Visual="arrow-right" />
			</Style>
		</Style>
	</Style>

	<Style Type="Slider" Id="horizontal">
		<Values Background="slider"
				Orientation="Horizontal"
				Width="100"
				Height="25" />
		<Style Type="Button" Id="thumb">
			<Values Background="slider-knob"
					HoveredBackground="slider-knob-over"
					PressedBackground="slider-knob-down"
					Width="25"
					Height="25"/>
		</Style>
	</Style>

	<Style Type="Slider" Id="vertical">
		<Values Background="slider-vertical"
				Orientation="Vertical"
				Height="100"
				Width="25" />
		<Style Type="Image">
			<Values Visual="slider-knob"
					HoveredVisual="slider-knob-over"
					PressedVisual="slider-knob-down" />
		</Style>
	</Style>

	<Style Type="ProgressBar" Id="horizontal">
		<Values Background="progressbar"
				Orientation="Horizontal"
				Filler="progressbar-filled"
				Width="100"
				Height="25" />
	</Style>

	<Style Type="ProgressBar" Id="vertical">
		<Values Background="progressbar-vertical"
				Orientation="Vertical"
				Filler="progressbar-filled-vertical"
				Height="100"
				Width="25" />
	</Style>

	<Style Type="HorizontalSeparator">
		<Values Image="separator-menu" Thickness="4" />
	</Style>

	<Style Type="VerticalSeparator">
		<Values Image="separator" Thickness="3" />
	</Style>

	<Style Type="ListView">
		<Values Background="button"
				HorizontalAlignment="Stretch"
				VerticalAlignment="Stretch" />
		<Style Type="ScrollViewer">
			<Values  />
		</Style>
		<Style Type="Separator">
			<Values Padding="0, 2"
					Image="separator-menu"
					Thickness="4" />
		</Style>
		<Style Type="SelectableItemPresenter" Id="item">
			<Values HoveredBackground="button-over"
				    SelectionBackground="button-down" />
		</Style>
	</Style>

	<Style Type="SelectableItem">
		<Values HoveredBackground="button-over"
				Padding="5, 0"
				PressedBackground="list-selection"
				Height="25"/>
		<Style Type="Label">
			<Values Font="default-font"
					TextColor="white"
					DisabledTextColor="gray"
					VerticalAlignment="Center"/>
		</Style>
	</Style>

	<Style Type="ComboBox">
		<Values Background="field-border-default"
				HoveredBackground="field-border-hovered"
				DisabledBackground="field-border-disabled"
				FocusedBackground="field-border-focused"
				Height="25" />
		<Style Type="ContentControl" Id="display">
			<Values Padding="5, 2, 5, 2" />
		</Style>
	</Style>

	<Style Type="TabControl">
		<Values ButtonSpacing="0"
				HorizontalAlignment="Stretch"
				VerticalAlignment="Stretch"/>
		<Style Type="Button" Id="tab-header">
			<Values HoveredBackground="button-over"
					Padding="2"
					PressedBackground="list-selection" />
			<Style Type="Label">
				<Values Font="default-font"
						TextColor="white"
						DisabledTextColor="gray" />
			</Style>
			<Style Type="Image">
				<Values Width="24"
						Height="24"/>
			</Style>
		</Style>
		<Style Type="ContentControl" Id="tab-content">
			<Values Background="window"
					Padding="5"
					VerticalAlignment="Stretch"
					HorizontalAlignment="Stretch" />
		</Style>
		<Style Type="CloseButton">
			<Values HoveredBackground="button-over" Padding="5, 0" PressedBackground="button-red" />
			<Style Type="Image">
				<Values Image="icon-close" />
			</Style>
		</Style>
	</Style>

	<Style Type="MenuItemView">
		
	</Style>

	<Style Type="MenuItemButton">
		
	</Style>

	<Style Type="Tree">
		<Values SelectionBackground="tree-selection" SelectionHoverBackground="button-over" />
		<Style Type="Mark">
			<Style Type="Image">
				<Values Image="tree-plus" PressedImage="tree-minus" />
			</Style>
		</Style>
		<Style Type="Label">
			<Values Font="default-font" TextColor="white" DisabledTextColor="gray" />
		</Style>
	</Style>

	<Style Type="HorizontalMenu">
		<Values Background="button" SelectionHoverBackground="button-over" SelectionBackground="button-down" SpecialCharColor="red" />
		<Style Type="Label">
			<Values Font="default-font" TextColor="white" DisabledTextColor="gray" Padding="10, 0" />
		</Style>
		<Style Type="Separator">
			<Values Image="separator" Thickness="3" />
		</Style>
	</Style>

	<Style Type="VerticalMenu">
		<Values Background="button" Border="#1BA1E2" BorderThickness="1" SelectionHoverBackground="button-over" SelectionBackground="button-down" SpecialCharColor="red" />
		<Style Type="Image">
			<Values Padding="10, 0, 0, 0" />
		</Style>
		<Style Type="Label">
			<Values Font="default-font" TextColor="white" DisabledTextColor="gray" Padding="10, 0" />
		</Style>
		<Style Type="Shortcut">
			<Values Font="default-font" TextColor="white" DisabledTextColor="gray" Padding="0, 0, 10, 0" />
		</Style>
		<Style Type="Separator">
			<Values Padding="0, 2" Image="separator-menu" Thickness="4" />
		</Style>
	</Style>

	<Style Type="Window">
		<Values Background="window_border_default" 
				ActiveBackground="window_border_default"
				InactiveBackground="window_boder_inactivate"
				Padding="5" />
		<Style Type="Label" 
			   Id="Title">
			<Values Font="header-font" 
					TextColor="white"
					HorizontalAlignment="Center"/>
		</Style>
		<Style Type="Button" 
			   Id="CloseButton">
			<Values Width="20"
					Height="20"
					HoveredBackground="button-over"
					PressedBackground="button-red" />
			<Style Type="Image" Id="Icon">
				<Values Image="window_close_icon" />
			</Style>
		</Style>
	</Style>

	<Style Type="FileDialog" ApplyFor="Window">
		<Values IconDrive="icon-drive" 
				IconFolder="icon-folder" 
				IconFile="icon-file"
				Width="600" 
				Height="400" />
		<Style Type="Button" Id="back-button">
			<Values Width="28"
					Height="28"
					ContentHorizontalAlignment="Center"
					ContentVerticalAlignment="Center"/>
			<Style Type="Image">
				<Values Visual="icon-arrow-left" />
			</Style>
		</Style>
		<Style Type="Button" Id="forward-button">
			<Values Width="28"
					Height="28"
					ContentHorizontalAlignment="Center"
					ContentVerticalAlignment="Center"/>
			<Style Type="Image">
				<Values Visual="icon-arrow-right" />
			</Style>
		</Style>
		<Style Type="Button" Id="parent-button">
			<Values Width="28"
					Height="28"
					ContentHorizontalAlignment="Center"
					ContentVerticalAlignment="Center"/>
			<Style Type="Image">
				<Values Visual="icon-folder-parent" />
			</Style>
		</Style>
		<Style Type="Button" Id="refresh-button">
			<Values Width="28"
					Height="28"
					ContentHorizontalAlignment="Center"
					ContentVerticalAlignment="Center"/>
			<Style Type="Image">
				<Values Visual="icon-folder-parent" />
			</Style>
		</Style>
	</Style>

	<Style Type="ColorPickerDialog">
		<Values Background="window" Padding="5" CheckerBoard="color-picker-checkerboard" SelectionBackground="button-down" SelectionHoverBackground="button-over" Wheel="color-picker-wheel" Gradient="color-picker-gradient" VSPickerKnob="vspicker-knob" Width="450" Height="350" />
		<Style Type="Title">
			<Values Font="default-font" TextColor="white" />
		</Style>
		<Style Type="CloseButton">
			<Values HoveredBackground="button-over" Padding="5, 0" PressedBackground="button-red" />
			<Style Type="Image">
				<Values Image="icon-close" />
			</Style>
		</Style>
	</Style>

	<Style Type="Inspector">
		<Values ItemHeight="25"
				LabelWidth="150"/>
		<Style Type="Label" Id="header">
			<Values HorizontalAlignment="Stretch"
					Font.Size="15"
					Font.Weight="Bold" />
		</Style>
	</Style>

</Stylesheet>