name=classic
filename=classic.atlas
output=../

alias=true
alphaThreshold=0
debug=false
duplicatePadding=false
edgePadding=true
fast=false
filterMag=Nearest
filterMin=Nearest
ignoreBlankImages=true
maxHeight=2048
maxWidth=2048
minHeight=16
minWidth=16
paddingX=2
paddingY=2
pot=true
mof=false
rotation=false
stripWhitespaceX=false
stripWhitespaceY=false
wrapX=ClampToEdge
wrapY=ClampToEdge
premultiplyAlpha=false
grid=false
square=false
bleed=true
limitMemory=true
useIndexes=true
prettyPrint=false
legacyOutput=false

scaleFactors=[{suffix:"",factor:1,resampling:bicubic}]
inputFiles=[{path:sasogine_surface_classic_archive-file-icon.png,type:Input,regionName:null},{path:sasogine_surface_classic_button-arrow-up-icon_copy_3.png,type:Input,regionName:null},{path:sasogine_surface_classic_checkbox-unchecked-disabled.png,type:Input,regionName:null},{path:sasogine_surface_classic_checkbox-unchecked-hovered.png,type:Input,regionName:null},{path:sasogine_surface_classic_image-file-icon.png,type:Input,regionName:null},{path:sasogine_surface_classic_inspector-value-clear_icon.png,type:Input,regionName:null},{path:sasogine_surface_classic_item-boder-selected.png,type:Input,regionName:null},{path:sasogine_surface_classic_item-border-hovered.png,type:Input,regionName:null},{path:sasogine_surface_classic_map-file-icon.png,type:Input,regionName:null},{path:sasogine_surface_classic_menu-arrow-down_icon.png,type:Input,regionName:null},{path:sasogine_surface_classic_menu-arrow-left-icon.png,type:Input,regionName:null},{path:sasogine_surface_classic_menu-arrow-right-icon.png,type:Input,regionName:null},{path:sasogine_surface_classic_menu-arrow-up-icon.png,type:Input,regionName:null},{path:sasogine_surface_classic_menu-check-mark-icon.png,type:Input,regionName:null},{path:sasogine_surface_classic_menu-radio-mark-icon.png,type:Input,regionName:null},{path:sasogine_surface_classic_music-file-icon.png,type:Input,regionName:null},{path:sasogine_surface_classic_network-icon.png,type:Input,regionName:null},{path:sasogine_surface_classic_radiobutton-checked-default.png,type:Input,regionName:null},{path:sasogine_surface_classic_radiobutton-checked-disabled.png,type:Input,regionName:null},{path:sasogine_surface_classic_radiobutton-checked-hovered.png,type:Input,regionName:null},{path:sasogine_surface_classic_radiobutton-unchecked-default.png,type:Input,regionName:null},{path:sasogine_surface_classic_radiobutton-unchecked-disabled.png,type:Input,regionName:null},{path:sasogine_surface_classic_radiobutton-unchecked-hovered.png,type:Input,regionName:null},{path:sasog